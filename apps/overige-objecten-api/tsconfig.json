{
  "compilerOptions": {
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "target": "es2022",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "declaration": true,
    "module": "es2022",
    "outDir": "dist",
    "lib": ["ES2021", "DOM"],
    "strict": true
  },
  "include": ["src/**/*", "./jest.config.ts", "./global.d.ts", "./vite.config.ts"],
  "exclude": ["node_modules", "**/*.test.ts", "./src/types/openapi.ts"]
}
