{
  "compilerOptions": {
    "jsx": "react-jsx",
    "target": "ES2020",
    "module": "ES2022",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "strict": true,
    "types": ["jest", "node"],
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@utrecht/*": ["../../node_modules/@utrecht/*"]
    }
  },
  "include": ["**/*.test.tsx", "**/*.test.ts", "tests"]
}
