{
  "name": "@frameless/pdc-sc",
  "version": "0.1.0",
  "private": true,
  "author": "@frameless",
  "type": "module",
  "description": "Utrecht PDC Samenwerkende Catalogi(SC) application",
  "license": "EUPL-1.2",
  "keywords": [],
  "scripts": {
    "prebuild": "pnpm clean",
    "build": "tsup",
    "watch": "tsc -p ./tsconfig.json  -w",
    "start": "node dist/server.js",
    "dev": "nodemon dist/server.js",
    "clean": "rimraf dist",
    "lint": "eslint --report-unused-disable-directives .",
    "lint:fix": "eslint --fix .",
    "lint-build": "tsc --noEmit --project tsconfig.json",
    "codegen": "wait-on http://localhost:1337 && graphql-codegen"
  },
  "dependencies": {
    "@frameless/samenwerkende-catalogi": "workspace:*",
    "@frameless/utils": "workspace:*",
    "@utrecht/component-library-react": "13.0.2",
    "dotenv": "16.3.2",
    "express": "4.18.2",
    "react": "19.2.6"
  },
  "devDependencies": {
    "@frameless/eslint-config": "1.2.0",
    "@graphql-codegen/cli": "5.0.2",
    "@graphql-codegen/client-preset": "4.1.0",
    "nodemon": "3.0.3",
    "tsup": "8.5.1",
    "wait-on": "9.0.10"
  },
  "repository": {
    "type": "git+ssh",
    "url": "git@github.com:frameless/strapi.git",
    "directory": "apps/pdc-sc"
  },
  "engines": {
    "node": "24.x.x",
    "pnpm": "10.23.0"
  }
}
