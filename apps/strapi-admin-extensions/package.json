{
  "name": "@frameless/strapi-admin-extensions",
  "version": "3.0.2",
  "private": true,
  "author": "@frameless",
  "description": "Strapi Admin Extensions",
  "license": "EUPL-1.2",
  "keywords": [],
  "scripts": {
    "prebuild": "pnpm clean",
    "build": "npm-run-all --parallel build:*",
    "build:server": "tsc -p ./tsconfig.json",
    "watch": "tsc -p ./tsconfig.json  -w",
    "start": "NODE_ENV=production node ./dist/src/server.js",
    "dev": "NODE_ENV=development nodemon src/server.ts",
    "clean": "rimraf dist src/types tmp",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint --report-unused-disable-directives .",
    "lint:fix": "eslint --fix .",
    "lint-build": "tsc --noEmit --project tsconfig.json"
  },
  "dependencies": {
    "@frameless/utils": "workspace:*",
    "@types/node": "24.12.0",
    "cors": "2.8.5",
    "csv-parser": "3.0.0",
    "dompurify": "3.2.1",
    "dotenv": "16.4.5",
    "express": "4.21.0",
    "js-yaml": "4.1.0",
    "lodash.memoize": "4.1.2",
    "morgan": "1.10.0",
    "p-limit": "3.0.0",
    "uuid": "13.0.0"
  },
  "devDependencies": {
    "@frameless/eslint-config": "1.2.0",
    "@types/cors": "2.8.17",
    "@types/dompurify": "3.2.0",
    "@types/lodash.memoize": "4.1.9",
    "@types/morgan": "1.9.9",
    "@types/supertest": "6.0.2",
    "@vitest/ui": "2.1.8",
    "jsdom": "25.0.1",
    "nodemon": "3.1.7",
    "rimraf": "6.0.1",
    "vitest": "2.1.8"
  },
  "repository": {
    "type": "git+ssh",
    "url": "git@github.com:frameless/strapi.git",
    "directory": "apps/strapi-admin-extensio0s"
  }
}
