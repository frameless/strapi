{
  "name": "@frameless/strapi-admin-extensions",
  "version": "3.0.2",
  "private": true,
  "author": "@frameless",
  "description": "Strapi Admin Extensions",
  "license": "EUPL-1.2",
  "type": "module",
  "keywords": [],
  "scripts": {
    "prebuild": "pnpm clean",
    "build": "npm-run-all --parallel build:*",
    "build:server": "tsup",
    "build:openapi": "mkdir -p dist/docs && cp -R src/docs/* dist/docs/",
    "watch": "tsup --watch",
    "start": "NODE_ENV=production node ./dist/server.js",
    "dev": "nodemon",
    "clean": "rimraf dist src/types tmp",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint --report-unused-disable-directives .",
    "lint:fix": "eslint --fix .",
    "lint-build": "tsc --noEmit --project tsconfig.json"
  },
  "dependencies": {
    "@frameless/utils": "workspace:*",
    "cors": "2.8.6",
    "csv-parser": "3.2.0",
    "dompurify": "3.4.1",
    "dotenv": "17.4.2",
    "express": "4.22.1",
    "js-yaml": "4.1.1",
    "lodash.memoize": "4.1.2",
    "morgan": "1.10.1",
    "p-limit": "7.3.0",
    "uuid": "14.0.0"
  },
  "devDependencies": {
    "@frameless/eslint-config": "1.2.0",
    "@types/cors": "2.8.19",
    "@types/dompurify": "3.2.0",
    "@types/lodash.memoize": "4.1.9",
    "@types/morgan": "1.9.10",
    "@types/node": "24.12.2",
    "@types/supertest": "6.0.3",
    "@vitest/ui": "3.2.6",
    "jsdom": "25.0.1",
    "nodemon": "3.1.14",
    "rimraf": "6.1.3",
    "tsup": "8.5.1",
    "vitest": "3.2.6"
  },
  "repository": {
    "type": "git+ssh",
    "url": "git@github.com:frameless/strapi.git",
    "directory": "apps/strapi-admin-extensio0s"
  },
  "engines": {
    "node": "24.x.x",
    "pnpm": "10.23.0"
  }
}
