{
  "compilerOptions": {
    "jsx": "react",
    "moduleResolution": "bundler",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "declaration": true,
    "module": "es2022",
    "lib": ["ES2021", "DOM"],
    "strict": true,
    "outDir": "dist"
  },
  "include": ["src/**/*", "./vitest.config.ts"],
  "exclude": ["node_modules", "**/*.test.ts", "./src/types/openapi.ts"]
}
