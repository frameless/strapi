    "@utrecht/design-tokens": "5.0.0",
    "@utrecht/web-component-library-react": "3.0.12",
    "accept-language": "3.0.18",
    "classnames": "2.3.3",
    "i18next": "22.5.1",
    "i18next-browser-languagedetector": "7.0.2",
