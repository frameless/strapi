{
  "name": "@frameless/samenwerkende-catalogi",
  "version": "0.0.0",
  "private": false,
  "sideEffects": true,
  "author": "@frameless",
  "description": "A Nodejs application that generate the samenwerkende-catalogi XML",
  "license": "EUPL-1.2",
  "keywords": [],
  "repository": {
    "type": "git+ssh",
    "url": "git@github.com:frameless/strapi.git",
    "directory": "packages/samenwerkende-catalogi"
  },
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "files": [
    "./dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "dependencies": {
    "@frameless/catalogi-data": "0.0.1",
    "@frameless/upl": "0.0.1",
    "dotenv": "17.4.2",
    "xmlbuilder2": "3.0.2"
  },
  "scripts": {
    "prebuild": "pnpm clean",
    "builds": "rollup -c ",
    "build": "pnpm build:browser && pnpm build:node",
    "build:browser": "tsc -p ./tsconfig.browser.json",
    "build:node": "tsc -p ./tsconfig.node.json",
    "clean": "rimraf dist",
    "lint": "eslint --report-unused-disable-directives .",
    "lint:fix": "eslint --fix .",
    "lint-build": "tsc --noEmit --project tsconfig.json"
  }
}
