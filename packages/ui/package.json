{
  "name": "@frameless/ui",
  "version": "0.1.2",
  "description": "A shared ui library",
  "type": "module",
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.esm.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js",
      "types": "./dist/src/index.d.ts"
    },
    "./dist/bundle.css": "./dist/bundle.css"
  },
  "private": true,
  "files": [
    "dist/"
  ],
  "keywords": [],
  "repository": {
    "type": "git+ssh",
    "url": "git@github.com:frameless/strapi.git",
    "directory": "packages/ui"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "author": {
    "name": "@frameless"
  },
  "engines": {
    "node": ">=22.0.0 <25",
    "pnpm": "10.23.0"
  },
  "license": "EUPL-1.2",
  "peerDependencies": {
    "@utrecht/component-library-react": ">=8",
    "@utrecht/web-component-library-react": ">=3",
    "focus-trap-react": ">=10",
    "lodash.kebabcase": ">=4",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "react-loading-skeleton": ">=3",
    "react-markdown": ">=10",
    "rehype-raw": ">=7"
  },
  "peerDependenciesMeta": {
    "react-loading-skeleton": {
      "optional": true
    },
    "react-markdown": {
      "optional": true
    },
    "rehype-raw": {
      "optional": true
    }
  },
  "scripts": {
    "prebuild": "pnpm clean",
    "build": "vite build",
    "watch": "vite build --watch",
    "preview": "vite preview",
    "clean": "rimraf dist .rollup.cache",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "lint": "eslint --report-unused-disable-directives .",
    "lint:fix": "eslint --fix .",
    "lint-build": "tsc --noEmit --project tsconfig.json"
  },
  "devDependencies": {
    "@frameless/eslint-config": "1.2.0",
    "@jest/globals": "30.3.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/jest": "30.0.0",
    "@types/lodash.kebabcase": "4.1.9",
    "@types/react": "19.1.4",
    "@types/react-dom": "19.1.4",
    "@utrecht/backdrop-css": "2.0.1",
    "@utrecht/component-library-react": "14.0.0",
    "@utrecht/web-component-library-react": "4.0.4",
    "@vitejs/plugin-react": "6.0.1",
    "autoprefixer": "10.4.17",
    "identity-obj-proxy": "3.0.0",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-markdown": "10.1.0",
    "rehype-raw": "7.0.0",
    "sass": "1.98.0",
    "ts-jest": "29.2.3",
    "ts-node": "10.9.2",
    "vite": "8.0.0",
    "vite-plugin-dts": "4.5.4"
  },
  "dependencies": {
    "classnames": "2.3.3",
    "lodash.kebabcase": "4.1.1"
  }
}
